<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detailMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_mint"
    android:orientation="vertical"
    android:padding="22dp"
    tools:context=".DetailActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Task Detail"
        android:textColor="@color/study_green_dark"
        android:textSize="26sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/panel_background"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/detailTitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task title"
            android:textColor="@color/study_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailCategoryTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Category: Android"
            android:textColor="@color/study_muted"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/detailPriorityTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Priority: Important"
            android:textColor="@color/study_green_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailTipTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:text="Study tip"
            android:textColor="@color/study_text"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
